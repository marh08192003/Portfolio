---
import { getCollection, type CollectionEntry } from "astro:content";
import { techColors, defaultTechColor } from "../utils/techColors"; // Clean import!

type Project = CollectionEntry<"projects">;

interface Props {
  lang: "es" | "en";
}

const { lang } = Astro.props;

const projects = (await getCollection("projects"))
  .filter((project) => project.data.lang === lang)
  .sort(
    (a, b) =>
      Number(b.data.isFeatured ?? false) - Number(a.data.isFeatured ?? false),
  );
---

<section id="projects" class="py-16 border-t border-slate-100 dark:border-slate-800/60">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <h2
      class="text-3xl font-bold tracking-tight text-slate-900 dark:text-white mb-10 flex items-center gap-3"
    >
      <span class="w-2 h-7 bg-emerald-500 rounded-full inline-block"></span>
      {lang === "es" ? "Proyectos Destacados" : "Featured Projects"}
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {
        projects.map((project: Project) => (
          <article class="group relative flex flex-col justify-between p-6 bg-white dark:bg-slate-900 border border-slate-200/80 dark:border-slate-800 rounded-2xl hover:shadow-xl hover:border-emerald-500/30 dark:hover:border-emerald-500/20 transition-all duration-300">
            <div>
              {/* Featured Badge or Status */}
              <div class="flex items-center justify-between mb-4">
                {project.data.isFeatured && (
                  <span class="text-xs font-medium text-emerald-600 dark:text-emerald-400 bg-emerald-50 dark:bg-emerald-500/10 px-2.5 py-1 rounded-md">
                    ★ {lang === "es" ? "Destacado" : "Featured"}
                  </span>
                )}
              </div>

              {/* Title */}
              <h3 class="text-xl font-bold text-slate-900 dark:text-white group-hover:text-emerald-500 dark:group-hover:text-emerald-400 transition-colors duration-200">
                {project.data.title}
              </h3>

              {/* Business Description */}
              <p class="mt-3 text-slate-600 dark:text-slate-400 text-sm leading-relaxed line-clamp-3">
                {project.data.businessDescription}
              </p>

              {/* Tech Stack Tags with dynamic coloring */}
              <div class="flex flex-wrap gap-1.5 mt-5">
                {project.data.tags.map((tag: string) => (
                  <span
                    class={`text-xs font-medium px-2.5 py-1 rounded-md border ${techColors[tag] || defaultTechColor}`}
                  >
                    {tag}
                  </span>
                ))}
              </div>
            </div>

            {/* Action Link */}
            <div class="mt-6 pt-4 border-t border-slate-100 dark:border-slate-800/60 flex items-center justify-end">
              <a
                href={`/blog/${project.id}`}
                class="inline-flex items-center text-sm font-semibold text-emerald-600 dark:text-emerald-400 group-hover:underline gap-1"
              >
                {lang === "es" ? "Ver caso de estudio" : "View case study"}
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4 transform group-hover:translate-x-1 transition-transform"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 5l7 7-7 7"
                  />
                </svg>
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
