---
interface Props {
  lang: "es" | "en";
  toggleHref?: string;
}

const { lang, toggleHref } = Astro.props;

const navItems = {
  es: [{ name: "Proyectos", href: "/Portfolio/#projects" }],
  en: [{ name: "Projects", href: "/Portfolio/en#projects" }],
};

const currentNav = navItems[lang];

const toggleLangHref = toggleHref || (lang === "es" ? "/Portfolio/en" : "/Portfolio/");
---

<header
  class="sticky top-0 z-50 w-full border-b border-slate-100/80 dark:border-slate-800/60 bg-white/80 dark:bg-slate-900/80 backdrop-blur-md transition-colors duration-300"
>
  <div
    class="max-w-5xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between"
  >
    <a
      href={lang === "es" ? "/" : "/en"}
      class="text-lg font-bold tracking-tight text-slate-900 dark:text-white hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
    >
      MR<span class="text-blue-600 dark:text-blue-400">.</span>
    </a>

    <nav class="flex items-center gap-6">
      <ul class="hidden sm:flex items-center gap-6">
        {
          currentNav.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-sm font-medium text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white transition-colors"
              >
                {item.name}
              </a>
            </li>
          ))
        }
      </ul>

      <div class="hidden sm:block w-px h-4 bg-slate-200 dark:bg-slate-800">
      </div>

      <div class="flex items-center gap-2">
        <button
          id="theme-toggle-btn"
          type="button"
          aria-label="Toggle theme"
          class="p-2 rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors"
        >
          <svg
            id="theme-toggle-sun"
            class="hidden h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M16.243 17.657l.707.707M6.343 6.343l.707-.707M14.5 12a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"
            ></path>
          </svg>
          <svg
            id="theme-toggle-moon"
            class="hidden h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
            ></path>
          </svg>
        </button>

        <a
          href={toggleLangHref}
          class="px-3 py-2 text-xs font-mono font-bold rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors"
          title={lang === "es" ? "Switch to English" : "Cambiar a Español"}
        >
          {lang === "es" ? "EN" : "ES"}
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  function initTheme() {
    const themeToggleBtn = document.getElementById("theme-toggle-btn");
    const sunIcon = document.getElementById("theme-toggle-sun");
    const moonIcon = document.getElementById("theme-toggle-moon");

    if (!themeToggleBtn || !sunIcon || !moonIcon) return;

    const isDark = document.documentElement.classList.contains("dark");
    if (isDark) {
      sunIcon.classList.remove("hidden");
      moonIcon.classList.add("hidden");
    } else {
      sunIcon.classList.add("hidden");
      moonIcon.classList.remove("hidden");
    }

    themeToggleBtn.addEventListener("click", () => {
      const currentDark = document.documentElement.classList.contains("dark");

      if (currentDark) {
        document.documentElement.classList.remove("dark");
        localStorage.setItem("theme", "light");
        sunIcon.classList.add("hidden");
        moonIcon.classList.remove("hidden");
      } else {
        document.documentElement.classList.add("dark");
        localStorage.setItem("theme", "dark");
        sunIcon.classList.remove("hidden");
        moonIcon.classList.add("hidden");
      }
    });
  }

  initTheme();
  document.addEventListener("astro:page-load", initTheme);
</script>
