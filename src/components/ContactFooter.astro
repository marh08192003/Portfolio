---
interface Props {
  lang: "es" | "en";
}

const { lang } = Astro.props;

const content = {
  es: {
    title: "Contacto",
    subtitle: "¿Quieres trabajar conmigo o hacerme una consulta? Escríbeme.",
    emailLabel: "Enviar correo electrónico",
    linkedinLabel: "Perfil de LinkedIn",
    githubLabel: "Perfil de GitHub",
    cvPath: "/cv/RiveraMiguel_CV.pdf",
    rights: "Todos los derechos reservados.",
  },
  en: {
    title: "Contact",
    subtitle: "Want to work together or have a question? Drop me a line.",
    emailLabel: "Send an email",
    linkedinLabel: "LinkedIn profile",
    githubLabel: "GitHub profile",
    cvPath: "/cv/en_RiveraMiguel_CV.pdf",
    rights: "All rights reserved.",
  },
};

const t = content[lang];

const socialLinks = {
  email: "mailto:rivera.miguel0819@gmail.com",
  linkedin: "https://www.linkedin.com/in/miguel-rivera-73186033b/",
  github: "https://github.com/marh08192003",
};
---

<footer
  class="mt-20 border-t border-slate-150 dark:border-slate-800/60 py-12 bg-transparent"
>
  <div class="max-w-4xl mx-auto px-4 text-center">
    <h2
      class="text-3xl font-bold tracking-tight text-slate-900 dark:text-white mb-3"
    >
      {t.title}
    </h2>
    <p
      class="text-slate-600 dark:text-slate-400 max-w-lg mx-auto mb-8 text-base leading-relaxed"
    >
      {t.subtitle}
    </p>

    <div
      class="flex flex-col sm:flex-row items-center justify-center gap-3 mb-12"
    >
      <div class="flex items-center gap-3 w-full sm:w-auto justify-center">
        <a
          href={socialLinks.email}
          aria-label={t.emailLabel}
          class="p-3 bg-slate-100 dark:bg-slate-900 text-slate-700 dark:text-slate-300 rounded-xl border border-slate-200/60 dark:border-slate-800 hover:bg-slate-200 dark:hover:bg-slate-800 transition-all focus:outline-none focus:ring-2 focus:ring-blue-500"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
            ></path>
          </svg>
        </a>

        <a
          href={socialLinks.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={t.linkedinLabel}
          class="p-3 bg-slate-100 dark:bg-slate-900 text-slate-700 dark:text-slate-300 rounded-xl border border-slate-200/60 dark:border-slate-800 hover:bg-blue-500 hover:text-white dark:hover:bg-blue-600 dark:hover:text-white transition-all focus:outline-none focus:ring-2 focus:ring-blue-500"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5"
            fill="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
            ></path>
          </svg>
        </a>

        <a
          href={socialLinks.github}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={t.githubLabel}
          class="p-3 bg-slate-100 dark:bg-slate-900 text-slate-700 dark:text-slate-300 rounded-xl border border-slate-200/60 dark:border-slate-800 hover:bg-slate-900 hover:text-white dark:hover:bg-slate-800 dark:hover:text-white transition-all focus:outline-none focus:ring-2 focus:ring-blue-500"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5"
            fill="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
            ></path>
          </svg>
        </a>
      </div>
    </div>

    <p class="text-xs font-mono text-slate-400 dark:text-slate-500">
      &copy; {new Date().getFullYear()} Miguel Rivera. {t.rights}
    </p>
  </div>
</footer>
